// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int     @id @default(autoincrement())
  nickname        String
  profileImageUrl String?
  totalTime       Int     @default(0)
  email           String? @unique
  password        String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  goals      Goal[]
  categories Category[]
  goalLogs   GoalLog[]
  timerLogs  TimerLog[]

  @@index([totalTime(sort: Desc)]) // 랭킹 조회용
  @@map("users")
}

model Category {
  id     Int     @id @default(autoincrement())
  userId Int?
  name   String
  unit   String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals Goal[]

  @@map("categories")
}

model Goal {
  id         Int @id @default(autoincrement())
  userId     Int
  categoryId Int

  title       String
  description String?
  status      String  @default("active")

  startDate DateTime @db.Timestamptz(3)
  endDate   DateTime @db.Timestamptz(3)

  currentValue Int @default(0)
  targetValue  Int
  quota        Int

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  goalLogs  GoalLog[]
  timerLogs TimerLog[]

  @@map("goals")
}

model GoalLog {
  id          Int      @id @default(autoincrement())
  achievedAt  DateTime @db.Timestamptz(3)
  targetValue Int?
  actualValue Int?
  timeSpent   Int?

  goalId Int
  userId Int

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([goalId, achievedAt])
  @@map("goal_logs")
}

model TimerLog {
  id          Int       @id @default(autoincrement())
  timerDate   DateTime? @db.Timestamptz(3)
  startTime   DateTime  @db.Timestamptz(3)
  endTime     DateTime? @db.Timestamptz(3)
  durationSec Int       @default(0)
  userId      Int

  goalId    Int
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endTime]) // 실행중 타이머 빠른 조회용
  @@map("timer_logs")
}
