{
  "name": "lampfire",
  "version": "1.0.0",
  "description": "Team 제이팍 - 등불 프로젝트의 백엔드 작업 공간",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,d.ts --exec npx ts-node --files src/main.ts",
    "build": "tsc && cp -r src/generated dist/src/",
    "start": "node dist/src/main.js",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "check": "eslint . && prettier . --check",
    "fix": "eslint . --fix && prettier . --write",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:format": "prisma format",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
